generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  name                 String?
  phone                String?
  avatarUrl            String?
  planTier             PlanTier             @default(free)
  planExpiresAt        DateTime?
  creditsBalance       Int                  @default(100)
  creditsLifetimeUsed  Int                  @default(0)
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  linkedinPostsToday   Int                  @default(0)
  linkedinPostsResetAt DateTime?
  platformLangPrefs    Json?
  onboardingCompleted  Boolean              @default(false)
  notifyOnPublish      Boolean              @default(true)
  notifyOnFailure      Boolean              @default(true)
  notifyWeeklyDigest   Boolean              @default(false)
  notifyWhatsappNumber String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  isAdmin              Boolean              @default(false)
  agentTasks           AgentTask[]
  apiKeys              ApiKey[]
  calendarItems        CalendarItem[]
  contentBrain         ContentBrain?
  contentSuggestions   ContentSuggestion[]
  generatedAssets      GeneratedAsset[]
  goldenExamplesLoop   GoldenExample[]
  marketIntelligence   MarketIntelligence[]
  plotComparables      PlotComparable[]
  postAnalytics        PostAnalytics[]
  projectAssets        ProjectAsset[]
  publishLogs          PublishLog[]
  socialAccounts       SocialAccount[]
  subscriptions        Subscription[]
  usageLogs            UsageLog[]
  webhookEndpoints     WebhookEndpoint[]
  websiteConnections   WebsiteConnection[]
  weeklyInsights       WeeklyInsight[]
  whatsappSequences    WhatsAppSequence[]
  leads                Lead[]
  abTests              ABTest[]

  @@map("users")
}

model MarketIntelligence {
  id              String             @id @default(cuid())
  userId          String
  platform        String
  postId          String?
  postUrl         String?
  author          String?
  content         String
  likes           Int                @default(0)
  comments        Int                @default(0)
  shares          Int                @default(0)
  engagementScore Float?
  postedAt        DateTime?
  scrapedAt       DateTime           @default(now())
  corridor        String?
  tags            String[]
  metadata        Json?
  source          IntelligenceSource @default(TAVILY)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([scrapedAt])
  @@map("market_intelligence")
}

model AgentTask {
  id               String    @id @default(cuid())
  userId           String
  goal             String
  source           String    @default("whatsapp")
  status           String    @default("processing")
  progress         Int       @default(0)
  currentAgent     String    @default("Orchestrator")
  inputContext     Json?
  deepResearchData Json?
  generatedContent Json?
  completedAt      DateTime?
  logs             Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("agent_tasks")
}

model ContentBrain {
  id                      String        @id @default(cuid())
  userId                  String        @unique
  brandName               String?
  brandDescription        String?
  industry                String?
  location                String?
  audienceDescription     String?
  tone                    String?
  primaryLanguage         LanguageType  @default(hinglish)
  secondaryLanguage       LanguageType?
  languageMixRules        String?
  ctas                    Json?
  contactPhone            String?
  contactEmail            String?
  contactWebsite          String?
  goldenExamples          String[]
  competitorHandles       String[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  contentDna              Json?
  customerType            String?
  propertyType            String?
  usps                    String[]
  contentPurpose          String?
  orchestratorChatHistory Json?
  orchestratorMemory      String?
  caoChannelData          Json?
  caoCustomAgents         Json?
  caoLastRunAt            DateTime?
  caoStrategy             Json?
  zapierWebhookUrl        String?
  crmConfig               Json?
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("content_brains")
}

model SocialAccount {
  id           String       @id @default(cuid())
  userId       String
  platform     PlatformType
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  accountId    String?
  accountName  String?
  pageId       String?
  pageName     String?
  channelId    String?
  channelName  String?
  isActive     Boolean      @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  metadata     Json?
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

model GeneratedAsset {
  id                String           @id @default(cuid())
  userId            String
  parentAssetId     String?
  sourceId          String?
  type              AssetType
  platform          PlatformType?
  language          LanguageType?
  title             String?
  body              String
  tags              String[]
  cta               String?
  notes             String?
  imageUrl          String?
  imagePrompt       String?
  qualityScore      Int?
  qualityIssues     Json?
  isGoldenExample   Boolean          @default(false)
  isCustomTemplate  Boolean          @default(false)
  templateName      String?
  templateVariables Json?
  publishCount      Int              @default(0)
  generationHash    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  calendarItems     CalendarItem[]
  parentAsset       GeneratedAsset?  @relation("AssetRemixes", fields: [parentAssetId], references: [id])
  remixes           GeneratedAsset[] @relation("AssetRemixes")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  postAnalytics     PostAnalytics[]
  publishLogs       PublishLog[]

  @@index([userId, platform, language])
  @@index([userId, createdAt])
  @@index([generationHash])
  @@map("generated_assets")
}

model CalendarItem {
  id               String          @id @default(cuid())
  userId           String
  generatedAssetId String?
  platform         PlatformType
  status           PostStatus      @default(draft)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  failedAt         DateTime?
  failureReason    String?
  retryCount       Int             @default(0)
  platformPostId   String?
  platformPostUrl  String?
  notes            String?
  isSuggested      Boolean         @default(false)
  festivalTag      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  generatedAsset   GeneratedAsset? @relation(fields: [generatedAssetId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishLogs      PublishLog[]
  leads            Lead[]
  abTestId         String?
  abVariant        String? // "A" or "B"
  abTest           ABTest?         @relation(fields: [abTestId], references: [id])

  @@index([userId, scheduledAt])
  @@index([userId, status])
  @@index([status, scheduledAt])
  @@map("calendar_items")
}

model PublishLog {
  id               String          @id @default(cuid())
  userId           String
  calendarItemId   String?
  generatedAssetId String?
  platform         PlatformType
  status           String
  platformPostId   String?
  platformPostUrl  String?
  errorMessage     String?
  errorCode        String?
  retryCount       Int             @default(0)
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  postAnalytics    PostAnalytics[]
  calendarItem     CalendarItem?   @relation(fields: [calendarItemId], references: [id])
  generatedAsset   GeneratedAsset? @relation(fields: [generatedAssetId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([userId, publishedAt])
  @@map("publish_logs")
}

model PostAnalytics {
  id               String          @id @default(cuid())
  userId           String
  publishLogId     String?
  generatedAssetId String?
  platform         PlatformType
  impressions      Int             @default(0)
  reach            Int             @default(0)
  likes            Int             @default(0)
  comments         Int             @default(0)
  shares           Int             @default(0)
  saves            Int             @default(0)
  views            Int             @default(0)
  clicks           Int             @default(0)
  engagementRate   Float?
  fetchedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  generatedAsset   GeneratedAsset? @relation(fields: [generatedAssetId], references: [id])
  publishLog       PublishLog?     @relation(fields: [publishLogId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  abTestId         String?
  abTest           ABTest?         @relation(fields: [abTestId], references: [id])

  @@index([userId, platform])
  @@index([publishLogId])
  @@map("post_analytics")
}

model WebsiteConnection {
  id             String    @id @default(cuid())
  userId         String
  websiteName    String
  websiteUrl     String
  webhookUrl     String
  apiKey         String    @default(cuid())
  isActive       Boolean   @default(true)
  lastSyncedAt   DateTime?
  totalPostsSent Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([apiKey])
  @@map("website_connections")
}

model ContentSuggestion {
  id              String        @id @default(cuid())
  userId          String
  topicSuggestion String
  reason          String
  urgency         UrgencyLevel  @default(medium)
  platform        PlatformType?
  templateType    String?
  isTrending      Boolean       @default(false)
  festivalTag     String?
  date            DateTime
  wasUsed         Boolean       @default(false)
  usedAt          DateTime?
  createdAt       DateTime      @default(now())
  pillar          String?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("content_suggestions")
}

model WeeklyInsight {
  id              String   @id @default(cuid())
  userId          String
  weekStartDate   DateTime
  insightText     String
  topObservations String[]
  thingsToStop    String[]
  contentIdea     String?
  dataSnapshot    Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@map("weekly_insights")
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  creditsUsed Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@map("usage_logs")
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  planTier          PlanTier
  billingCycle      BillingCycle
  status            SubscriptionStatus @default(active)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySubId     String?
  amountPaid        Int
  currency          String             @default("INR")
  gstAmount         Int?
  startedAt         DateTime           @default(now())
  expiresAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([razorpayOrderId])
  @@map("subscriptions")
}

model ApiKey {
  id           String    @id @default(cuid())
  userId       String
  keyHash      String    @unique
  keyPrefix    String
  name         String?
  lastUsedAt   DateTime?
  requestCount Int       @default(0)
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model WebhookEndpoint {
  id              String               @id @default(cuid())
  userId          String
  url             String
  secret          String
  events          String[]
  isActive        Boolean              @default(true)
  failureCount    Int                  @default(0)
  lastTriggeredAt DateTime?
  lastStatusCode  Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deliveryLogs    WebhookDeliveryLog[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webhook_endpoints")
}

model WebhookDeliveryLog {
  id                String          @id @default(cuid())
  webhookEndpointId String
  event             String
  payload           Json
  responseStatus    Int?
  responseBody      String?
  attemptNumber     Int             @default(1)
  success           Boolean         @default(false)
  deliveredAt       DateTime?
  createdAt         DateTime        @default(now())
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId])
  @@map("webhook_delivery_logs")
}

model FestivalCalendar {
  id                String   @id @default(cuid())
  name              String
  nameMarathi       String?
  nameHindi         String?
  date              DateTime
  year              Int
  type              String
  region            String   @default("all_india")
  contentAngle      String?
  suggestedTopics   String[]
  urgencyDaysBefore Int      @default(3)
  createdAt         DateTime @default(now())

  @@unique([name, year])
  @@index([date])
  @@map("festival_calendar")
}

model NagpurLocality {
  id              String   @id @default(cuid())
  name            String   @unique
  zone            String?
  connectedTo     String[]
  schools         String[]
  hospitals       String[]
  malls           String[]
  upcomingInfra   String[]
  avgPlotPriceMin Int?
  avgPlotPriceMax Int?
  priceUnit       String   @default("per_sqft")
  appreciationYoY String?
  distanceAirport String?
  distanceRailway String?
  distanceHighway String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("nagpur_localities")
}

model GenerationCache {
  id        String   @id @default(cuid())
  userId    String
  hash      String
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, hash])
  @@index([expiresAt])
  @@map("generation_cache")
}

model WhatsAppSequence {
  id          String                 @id @default(cuid())
  userId      String
  name        String
  description String?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  steps       WhatsAppSequenceStep[]
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("whatsapp_sequences")
}

model WhatsAppSequenceStep {
  id          String           @id @default(cuid())
  sequenceId  String
  stepNumber  Int
  delayDays   Int              @default(0)
  messageBody String
  assetId     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  sequence    WhatsAppSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId, stepNumber])
  @@map("whatsapp_sequence_steps")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("waitlist")
}

model ProjectAsset {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  fileType       String
  mimeType       String
  fileUrl        String
  fileSize       Int?
  corridor       String?
  projectName    String?
  useInChat      Boolean  @default(true)
  useAsKnowledge Boolean  @default(true)
  tags           String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fileType])
  @@index([userId, projectName])
  @@map("project_assets")
}

model SystemConfig {
  key   String @unique
  value String

  @@map("system_configs")
}

model JobRun {
  id          String    @id @default(cuid())
  jobType     String
  userId      String
  status      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, jobType, status])
  @@map("job_runs")
}

model SystemAlert {
  id         String    @id @default(cuid())
  type       String
  message    String
  severity   String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("system_alerts")
}

model GoldenExample {
  id                String   @id @default(cuid())
  userId            String
  platform          String
  postText          String
  engagementScore   Float
  structureAnalysis String?
  sourcePostId      String?
  usageCount        Int      @default(0)
  capturedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([engagementScore])
  @@map("golden_examples")
}

model PlotComparable {
  id               String    @id @default(cuid())
  userId           String
  corridor         String
  locality         String?
  city             String    @default("Nagpur")
  title            String?
  description      String?
  areaSqFt         Float?
  areaSqM          Float?
  priceTotal       Float?
  pricePerSqFt     Float?
  priceLabel       String?
  isNegotiable     Boolean   @default(false)
  possessionStatus String?
  source           String
  sourceUrl        String?
  listingId        String?
  postedAt         DateTime?
  scrapedAt        DateTime  @default(now())
  isVerified       Boolean   @default(false)
  isActive         Boolean   @default(true)
  reraNumber       String?
  tags             String[]
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, corridor])
  @@index([corridor, pricePerSqFt])
  @@index([scrapedAt])
  @@map("plot_comparables")
}

model Lead {
  id              String         @id @default(cuid())
  userId          String
  source          String // e.g., "LinkedIn", "Instagram", "WhatsApp", "Manual"
  name            String
  phone           String?
  email           String?
  status          String // "NEW", "CONTACTED", "INTERESTED", "VISITED", "BOOKED", "LOST"
  budget          Float?
  location        String?
  corridorNotes   String?
  campaignId      String? // Ref to AgentTask or Campaign item
  assetId         String? // Ref to specific GeneratedAsset that drove the lead
  notes           String?
  lastContactAt   DateTime?
  activities      LeadActivity[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarItemId  String?
  calendarItem    CalendarItem?  @relation(fields: [calendarItemId], references: [id])
  abTestId        String?
  abTest          ABTest?        @relation(fields: [abTestId], references: [id])

  @@index([userId, status])
  @@index([userId, source])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String // "PHONE_CALL", "WHATSAPP_DM", "SITE_VISIT", "OFFER_MADE"
  notes     String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_activities")
}

model ABTest {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  status             String // "RUNNING", "COMPLETED", "PAUSED"
  variantA_assetId   String
  variantB_assetId   String
  variantA_metrics   Json? // { reach, engagement, clicks, leads }
  variantB_metrics   Json?
  winningVariant     String? // "A" or "B"
  startedAt          DateTime @default(now())
  endedAt            DateTime?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarItems      CalendarItem[]
  postAnalytics      PostAnalytics[]
  leads              Lead[]

  @@index([userId])
  @@map("ab_tests")
}

enum IntelligenceSource {
  APIFY
  TAVILY
  MANUAL
}

enum PlatformType {
  instagram
  linkedin
  youtube
  x
  facebook
  facebook_ads
  google_business
  whatsapp
  website
}

enum LanguageType {
  english
  hindi
  marathi
  hinglish
}

enum PostStatus {
  draft
  ready
  scheduled
  publishing
  published
  failed
}

enum AssetType {
  post
  carousel
  shorts_script
  blog_article
  email_newsletter
  whatsapp_broadcast
  video_script
  image_prompt
}

enum PlanTier {
  free
  starter
  creator
  agency
}

enum UrgencyLevel {
  low
  medium
  high
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  trial
}
