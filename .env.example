# ──────────────────────────────────────────────────────────────────────────────
# Contentsathi — Environment Variables Configuration
# Copy this file to .env and fill in your actual keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── CORE INFRASTRUCTURE ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:port/dbname?sslmode=require"
NEXTAUTH_SECRET="your_32_char_random_secret"
NEXTAUTH_URL="http://localhost:3000"
TOKEN_ENCRYPTION_KEY="your_32_char_encryption_key" # For AES-256 tokens

# ── AI SERVICES (GEMINI / STABILITY) ─────────────────────────────────────────
GEMINI_API_KEY="AIza..."
STABILITY_API_KEY="sk-..." # Optional: For image generation
IMAGEN_API_KEY="AIza..."    # Optional: Alternative image gen
ENABLE_IMAGE_GENERATION="true"

# ── YOUTUBE RESEARCH ENGINE ──────────────────────────────────────────────────
YOUTUBE_API_KEY="AIza..."   # Required for YouTube Research Context

# ── SOCIAL CHANNELS (OAuth Credentials) ─────────────────────────────────────
# Create these in the respective Developer Portals

# LinkedIn
LINKEDIN_CLIENT_ID="86..."
LINKEDIN_CLIENT_SECRET="your_secret"

# Meta (Instagram & Facebook)
FACEBOOK_APP_ID="your_app_id"
FACEBOOK_APP_SECRET="your_app_secret"

# X (Twitter)
TWITTER_CLIENT_ID="your_client_id"
TWITTER_CLIENT_SECRET="your_client_secret"

# Google (YouTube Auth)
GOOGLE_CLIENT_ID="your_google_id"
GOOGLE_CLIENT_SECRET="your_google_secret"

# ── MEDIA STORAGE (CLOUDINARY) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_UPLOAD_PRESET="your_unsigned_preset"

# ── NOTIFICATIONS & PAYMENTS (PHASE U/V) ─────────────────────────────────────
RESEND_API_KEY="re_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# ── CRON PROTECTION ──────────────────────────────────────────────────────────
CRON_SECRET="your_cron_passphrase"
